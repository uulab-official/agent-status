{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Status",
  "version": "0.1.0",
  "identifier": "dev.agentstatus.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
